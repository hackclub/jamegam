# Copy to .env for local dev; set the same keys in Vercel project settings for prod.
# All values below are server-only secrets (read via $env/dynamic/private),
# EXCEPT PUBLIC_SITE_URL which is public (read via $env/dynamic/public).

# ---- Public site origin (canonical / og:url / schema URLs) ----
PUBLIC_SITE_URL=https://jamegam.hackclub.com  # no trailing slash; falls back to this if unset

# ---- Airtable (signup capture) ----
AIRTABLE_TOKEN=                       # base-scoped personal access token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE=Jame Gam Signups       # table name (or table id)

# ---- Loops (email) ----
LOOPS_API_KEY=
LOOPS_LIST_ID=                        # Jame Gam list id; written into the Airtable "Loops List - Jame Gam" field
LOOPS_TX_WELCOME_HAS_ACCOUNT=         # transactional id: low-key "come hang out" email
LOOPS_TX_WELCOME_NO_ACCOUNT=          # transactional id: "[action needed]" create-account email

# ---- Hack Club Auth (newcomer account + Slack) ----
HCA_ISSUER=https://auth.hackclub.com
HCA_CLIENT_ID=
HCA_CLIENT_SECRET=
HCA_SCOPE=openid email name slack_id verification_status  # must be a subset of the scopes ticked on the HCA app

# ---- Slack (auto-add to #jame-gam) ----
SLACK_BOT_TOKEN=xoxb-...
SLACK_JAMEGAM_CHANNEL_ID=C........

# ---- prize shop (/shop) ----
SESSION_SECRET=                       # HMAC key for the shop session cookie; generate: openssl rand -hex 32
# table names default to "Shop Orders" / "Submission Form" / "YSWS Project Submission";
# override with AIRTABLE_ORDERS_TABLE / AIRTABLE_SUBMISSIONS_TABLE / AIRTABLE_YSWS_TABLE if renamed

# ---- misc ----
JAM_LABEL=2026-06                     # which jam this signup batch belongs to
ORIGIN=https://jamegam.hackclub.com   # optional; falls back to the request origin
